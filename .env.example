# CmdAI Configuration
# Copy this file to .env and add your provider API keys.

# === Provider Priority (default fallback chain) ===
AI__Providers__0=openai
AI__Providers__1=azureopenai
AI__Providers__2=anthropic
AI__Providers__3=gemini

# === OpenAI (Primary) ===
AI__OpenAI__Enabled=true
AI__OpenAI__Endpoint=https://api.openai.com/v1/chat/completions
AI__OpenAI__Model=gpt-4.1-mini
AI__OpenAI__ApiKeys__0=your_openai_api_key_here
# AI__OpenAI__ApiKeys__1=optional_second_openai_key

# === Azure OpenAI (Fallback) ===
AI__AzureOpenAI__Enabled=true
AI__AzureOpenAI__Endpoint=https://your-resource.openai.azure.com/openai/v1/
AI__AzureOpenAI__Model=your-foundry-model-deployment
AI__AzureOpenAI__ApiKeys__0=your_azure_openai_key_here
# AI__AzureOpenAI__ApiKeys__1=optional_second_azure_key

# === Anthropic Claude (Fallback) ===
AI__Anthropic__Enabled=true
AI__Anthropic__Endpoint=https://api.anthropic.com/v1/messages
AI__Anthropic__Model=claude-3-5-haiku-latest
AI__Anthropic__ApiKeys__0=your_anthropic_api_key_here

# === Google Gemini (Fallback) ===
AI__Gemini__Enabled=true
AI__Gemini__Endpoint=https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent
AI__Gemini__Model=gemini-2.0-flash
AI__Gemini__ApiKeys__0=your_gemini_api_key_here

# === Optional: Advanced Settings ===
# AI__TimeoutSeconds=30
# AI__EnableAI=true
# AI__FallbackToPatterns=true

# === Memory (optional) ===
# Set this to a shared folder (e.g., OneDrive) to reuse memory across machines.
# Memory__StorePath=C:\Users\YourName\OneDrive\cmdai-memory
# Memory__HighConfidenceThreshold=0.62
# Memory__EnableRedaction=false
