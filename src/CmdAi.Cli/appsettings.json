{
  "CommandAI": {
    "DefaultTool": "git",
    "RequireConfirmation": true,
    "ContextAware": true,
    "SupportedTools": ["git", "az", "docker", "kubectl", "npm", "yarn"],
    "Extensions": {
      "WebCommandRepository": false,
      "AIResolver": true
    }
  },
  "AI": {
    "EnableAI": true,
    "Providers": ["openai", "azureopenai", "anthropic", "gemini"],
    "Provider": "openai",
    "OpenAI": {
      "Enabled": true,
      "Endpoint": "https://api.openai.com/v1/chat/completions",
      "Model": "gpt-4.1-mini",
      "ApiKeys": []
    },
    "AzureOpenAI": {
      "Enabled": true,
      "Endpoint": "",
      "Model": "model-router",
      "ApiKeys": []
    },
    "Anthropic": {
      "Enabled": true,
      "Endpoint": "https://api.anthropic.com/v1/messages",
      "Model": "claude-3-5-haiku-latest",
      "ApiKeys": []
    },
    "Gemini": {
      "Enabled": true,
      "Endpoint": "https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent",
      "Model": "gemini-2.0-flash",
      "ApiKeys": []
    },
    "TimeoutSeconds": 30,
    "FallbackToPatterns": true,
    "EnableLearning": true,
    "ConfidenceThreshold": 0.7
  },
  "Memory": {
    "StorePath": "",
    "CandidateCap": 200,
    "ListLimitDefault": 50,
    "HighConfidenceThreshold": 0.62,
    "EnableRedaction": false,
    "RedactionAllowlist": []
  }
}
